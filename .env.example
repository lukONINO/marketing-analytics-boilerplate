# =====================================================================
# marketing-analytics-boilerplate — environment variables
# Copy this file to `.env` and fill in the values. .env is gitignored.
# =====================================================================

# --- Google APIs ----------------------------------------------------
# Service account JSON for GSC + GA4. Choose ONE of:
#
# Option A (simplest for local dev): point at the JSON file on disk.
# Keep the file outside the repo, chmod 600. Example:
#   GSC_SERVICE_ACCOUNT_JSON_PATH=~/.secrets/acme-analytics-sa.json
GSC_SERVICE_ACCOUNT_JSON_PATH=
#
# Option B (required for cloud/CI where no filesystem persists):
# base64-encode the JSON and paste as a single line. Must be on ONE
# line — python-dotenv only reads the first line of a KEY=value:
#   base64 -i service-account.json | tr -d '\n' | pbcopy    # macOS
#   base64 -w 0 service-account.json                        # Linux
# The PATH option above wins if both are set.
GSC_SERVICE_ACCOUNT_JSON_B64=

# Property identifier for Search Console. For domain properties use
# the `sc-domain:` prefix; for URL-prefix properties paste the full URL.
GSC_SITE_URL=sc-domain:acme.io

# GA4 property ID (the numeric ID, NOT the measurement ID).
# Find it in GA4 → Admin → Property Settings.
GA4_PROPERTY_ID=

# --- Brand + site --------------------------------------------------
# Display name used in the dashboard UI (sidebar wordmark, page titles).
BRAND_DISPLAY_NAME=Acme

# Regex matched against query / prompt text to decide if it's a
# branded query. Default `acme` matches the placeholder; replace with
# your real brand. Use `(?:foo|bar)` for multiple brand surfaces.
BRAND_REGEX=acme

# Canonical origin used when GA4 returns bare page paths that need to
# be joined against GSC full URLs, and as the default sitemap host.
SITE_CANONICAL_ORIGIN=https://acme.io

# Optional: the page <title> of your homepage. Used by scrape_site.py
# to decide whether a fetched HTML page is a fresh shell vs the real
# server-rendered content. Override per your site's homepage title.
SITE_GENERIC_TITLE=Acme — your homepage title

# Optional: comma-separated list of low-frequency vocabulary that
# should weight the EN/DE translation-pair detector for content
# unique to your industry (regulatory acronyms, product names, etc.).
# Empty default = pair detector relies on URL stem + general signals.
RARE_SIGNALS=

# Operator email shown in the dashboard sidebar's "About" footer.
# Public — exposed to the browser. Use a no-reply or info@ address.
NEXT_PUBLIC_OPERATOR_EMAIL=you@acme.io

# --- Notion ---------------------------------------------------------
# The Notion MCP handles auth for Claude — this token is only needed if
# you ever want to invoke the Notion API directly from a Python script.
NOTION_INTEGRATION_TOKEN=

# Populated after the first skill run creates the database. Persists in
# config/notion_schema.yaml — this is just a convenience mirror.
NOTION_MARKETING_REPORTS_DB_ID=

# --- Runtime --------------------------------------------------------
TIMEZONE=UTC
LOG_LEVEL=INFO

# --- Notes on Peec MCP ----------------------------------------------
# Peec AI auth is handled by the Peec MCP configuration, not here.
# Install the Peec MCP into your Claude Code session and authenticate
# once; the skill files below pick it up automatically. The first
# skill run will print your project_id — paste it into a comment here
# for future reference if helpful.
#
# PEEC_PROJECT_ID=or_REPLACE_WITH_YOUR_PROJECT_ID  (informational only)
