# --- Secrets ---------------------------------------------------------
.env
.env.local
.env.*.local
data/gcp-key.json
*.pem
*.key

# --- Python ----------------------------------------------------------
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# --- Node / Next.js --------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
.eslintcache

# --- Generated data --------------------------------------------------
# All raw + processed data is regenerated by the Python scripts + skills.
# Don't commit it; it changes every day.
data/raw/peec/*.json
data/raw/gsc/*.json
data/raw/ga4/*.json
data/raw/llm_traffic/*.json
data/raw/content/**
data/processed/daily/*.json
data/processed/weekly/*.json
data/processed/page_clusters.json
data/processed/visibility_improvements.json
data/processed/readiness_extras.json

# --- Generated reports ----------------------------------------------
reports/*.md
reports/*.html
reports/*.json
!reports/.gitkeep

# --- Dashboard data (mostly Claude-written; commit example shapes) --
# The empty-shape example files are committed (they ship in the repo
# so the dashboard renders empty-state UI on a fresh clone). Real
# generated content overwrites them locally and gets ignored.
data/dashboard/_local_*.json

# --- Knowledge base --------------------------------------------------
# Re-fetched from upstream (Peec docs) by the knowledge-refresh skill.
# Don't commit copies — they could be third-party content.
knowledge/peec_blog/
knowledge/changelog.md
knowledge/peec-discovery-*.md

# --- IDE / editor ----------------------------------------------------
.vscode/
.idea/
.cursor/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- OS scratch ------------------------------------------------------
.history/
*.log
*.bak
